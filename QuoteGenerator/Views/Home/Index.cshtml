<div class="container">
    <h1>Random Quote Generator</h1>
    <p>Click the Generate button below to generate the Quote...</p>
    <div class="quote-container">
        <div class="quote-card">
            <p id="quote">Your quote will appear here..</p>
            <h3 id="author"> - Unknown</h3>
        </div>
        <div class="button-group">
            <button id="generateBtn">Generate Quote</button>
            <button id="refreshBtn">Refresh Quote</button>
            <button id="copyBtn">copy quote</button>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/site.js"></script>
}